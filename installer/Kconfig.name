# Responsible for setting:
#   PARAM_DISPLAY_NAME

config PARAM_DISPLAY_NAME
  string "Display name"
  generated_default "%s-%d" "PARAM_VENDOR UNIT_INDEX" if PARAM_VENDOR != "Other"
  default UNIT_NAME
  help
    The display name identifies your MMU in various UI's.
    It is NOT the identification name which is typically just "unit_X"

    Keep if reasonble short but it can contain spaces.
